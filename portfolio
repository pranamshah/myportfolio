<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PRANAM.SYS // Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#080b0f;--bg2:#0d1117;--surface:#111820;--surface2:#162030;
  --ink:#e8edf3;--mid:#8b9bb4;--muted:#445566;
  --accent:#00d4ff;--accent2:#0066ff;--accent3:#00ff88;
  --border:#1e2d3d;
  --glow:0 0 20px rgba(0,212,255,0.3);--glow2:0 0 40px rgba(0,212,255,0.15);
}
html{scroll-behavior:smooth;cursor:none;}
body{font-family:'JetBrains Mono',monospace;background:var(--bg);color:var(--ink);font-size:14px;line-height:1.6;overflow-x:hidden;}

#cursor{position:fixed;width:12px;height:12px;background:var(--accent);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:screen;transition:width .2s,height .2s,background .2s;}
#cursor-ring{position:fixed;width:36px;height:36px;border:1.5px solid rgba(0,212,255,.5);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .3s,height .3s,border-color .3s;}
#cursor.hover{width:20px;height:20px;background:var(--accent3);}
#cursor-ring.hover{width:56px;height:56px;border-color:var(--accent3);}
#cursor.click{transform:translate(-50%,-50%) scale(0.6);}
.trail{position:fixed;border-radius:50%;background:var(--accent);pointer-events:none;z-index:9997;transform:translate(-50%,-50%);opacity:0;}

#canvas-bg{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;opacity:.4;pointer-events:none;}
body::after{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");pointer-events:none;z-index:1;opacity:.3;}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.025) 2px,rgba(0,0,0,.025) 4px);pointer-events:none;z-index:2;}

nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:18px 48px;border-bottom:1px solid var(--border);background:rgba(8,11,15,.88);backdrop-filter:blur(20px);}
.nav-logo{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:var(--accent);text-decoration:none;letter-spacing:2px;text-transform:uppercase;}
.nav-logo span{color:var(--ink);opacity:.35;}
.nav-links{display:flex;gap:32px;list-style:none;align-items:center;}
.nav-links a{font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--mid);text-decoration:none;transition:color .2s;position:relative;}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--accent);transition:width .3s;}
.nav-links a:hover{color:var(--accent);}
.nav-links a:hover::after{width:100%;}
.nav-status{display:flex;align-items:center;gap:8px;font-size:10px;color:var(--accent3);letter-spacing:1px;}
.status-dot{width:6px;height:6px;border-radius:50%;background:var(--accent3);animation:pulse-dot 2s infinite;}
@keyframes pulse-dot{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,255,136,.4);}50%{opacity:.7;box-shadow:0 0 0 6px rgba(0,255,136,0);}}

.hero{min-height:100vh;display:flex;align-items:center;padding:0 48px;position:relative;z-index:10;max-width:1200px;margin:0 auto;}
.hero-meta{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:24px;opacity:0;animation:fadeUp .5s .2s forwards;}
.hero-meta::before{content:'> ';}
.hero-name{font-family:'Syne',sans-serif;font-size:clamp(56px,10vw,120px);font-weight:800;line-height:.92;letter-spacing:-3px;color:var(--ink);margin-bottom:8px;opacity:0;animation:fadeUp .6s .3s forwards;}
.hero-name .outline{color:transparent;-webkit-text-stroke:1.5px var(--accent);}
.glitch-wrap{position:relative;display:inline-block;}
.glitch-wrap::before,.glitch-wrap::after{content:attr(data-text);position:absolute;top:0;left:0;width:100%;height:100%;}
.glitch-wrap::before{color:var(--accent2);animation:glitch1 3.5s infinite;clip-path:polygon(0 20%,100% 20%,100% 40%,0 40%);}
.glitch-wrap::after{color:var(--accent3);animation:glitch2 3.5s infinite;clip-path:polygon(0 60%,100% 60%,100% 78%,0 78%);}
@keyframes glitch1{0%,88%,100%{transform:translate(0);}90%{transform:translate(-4px,1px);}93%{transform:translate(4px,-1px);}96%{transform:translate(-2px,2px);}}
@keyframes glitch2{0%,85%,100%{transform:translate(0);}87%{transform:translate(4px,-2px);}91%{transform:translate(-4px,1px);}95%{transform:translate(3px,-2px);}}
.hero-sub{font-size:clamp(14px,1.8vw,18px);color:var(--mid);font-weight:300;margin-bottom:48px;opacity:0;animation:fadeUp .6s .45s forwards;}
.typed-text{color:var(--accent3);}
.blink{display:inline-block;width:2px;height:1.1em;background:var(--accent3);vertical-align:middle;animation:blink-a .8s infinite;margin-left:2px;}
@keyframes blink-a{0%,100%{opacity:1;}50%{opacity:0;}}
.hero-cta{display:flex;gap:16px;flex-wrap:wrap;opacity:0;animation:fadeUp .6s .6s forwards;}
.btn-mag{position:relative;overflow:hidden;padding:14px 32px;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;text-decoration:none;border-radius:4px;transition:transform .2s,box-shadow .2s;cursor:none;display:inline-flex;align-items:center;gap:8px;border:none;}
.btn-p{background:var(--accent);color:#000;box-shadow:0 0 30px rgba(0,212,255,.3);}
.btn-p:hover{box-shadow:0 0 50px rgba(0,212,255,.6);}
.btn-o{background:transparent;color:var(--accent);border:1px solid var(--accent);}
.btn-o:hover{background:rgba(0,212,255,.06);}
.btn-ripple{position:absolute;border-radius:50%;background:rgba(255,255,255,.2);transform:scale(0);animation:ripple-a .6s linear;pointer-events:none;}
@keyframes ripple-a{to{transform:scale(4);opacity:0;}}
.hero-stats{display:flex;gap:48px;margin-top:64px;opacity:0;animation:fadeUp .6s .75s forwards;}
.stat-num{font-family:'Syne',sans-serif;font-size:42px;font-weight:800;color:var(--accent);line-height:1;margin-bottom:4px;}
.stat-label{font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;}
.scroll-ind{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;opacity:0;animation:fadeIn 1s 1.2s forwards;z-index:10;}
.scroll-line{width:1px;height:48px;background:linear-gradient(to bottom,var(--accent),transparent);animation:scroll-d 2s infinite;}
@keyframes scroll-d{0%{transform:scaleY(0);transform-origin:top;}50%{transform:scaleY(1);transform-origin:top;}51%{transform-origin:bottom;}100%{transform:scaleY(0);transform-origin:bottom;}}

.sec{position:relative;z-index:10;max-width:1200px;margin:0 auto;padding:100px 48px;}
.sec-dark{position:relative;z-index:10;padding:100px 0;background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.sec-dark .sec-inner{max-width:1200px;margin:0 auto;padding:0 48px;}
.sec-lbl{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:8px;display:flex;align-items:center;gap:6px;}
.sec-lbl::before{content:'// ';}
.sec-h{font-family:'Syne',sans-serif;font-size:clamp(34px,5vw,58px);font-weight:800;letter-spacing:-1.5px;color:var(--ink);margin-bottom:48px;line-height:1;}
.sec-h .dim{color:var(--muted);font-weight:400;}
.corner{position:absolute;width:20px;height:20px;border-color:rgba(0,212,255,.3);border-style:solid;}
.ctlr{top:16px;left:16px;border-width:1px 0 0 1px;}
.ctrr{top:16px;right:16px;border-width:1px 1px 0 0;}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:start;}
.terminal{background:var(--surface);border:1px solid var(--border);border-radius:8px;overflow:hidden;box-shadow:var(--glow2);}
.t-bar{background:#111c28;padding:10px 16px;display:flex;align-items:center;gap:7px;border-bottom:1px solid var(--border);}
.td{width:10px;height:10px;border-radius:50%;}
.t-title{font-size:11px;color:var(--muted);margin-left:8px;letter-spacing:1px;}
.t-body{padding:22px;font-size:12.5px;line-height:2.1;}
.tp{color:var(--accent3);}
.tc{color:var(--accent);}
.to{color:var(--mid);}
.th{color:var(--ink);}
.ts{color:#ffbd2e;}
.about-text p{color:var(--mid);font-size:14px;font-weight:300;margin-bottom:18px;line-height:1.85;}
.skill-sec{margin-top:32px;}
.skill-lbl{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:14px;}
.skill-chips{display:flex;flex-wrap:wrap;gap:10px;}
.chip{font-size:11px;font-weight:500;letter-spacing:1px;color:var(--accent);background:rgba(0,212,255,.07);border:1px solid rgba(0,212,255,.18);padding:6px 14px;border-radius:4px;}

/* TIMELINE */
.tl-item{display:grid;grid-template-columns:180px 1fr;gap:40px;padding:40px 0;border-bottom:1px solid var(--border);position:relative;}
.tl-item::before{content:'';position:absolute;left:179px;top:0;bottom:0;width:1px;background:var(--border);}
.tl-item::after{content:'';position:absolute;left:173px;top:44px;width:13px;height:13px;border-radius:50%;background:var(--bg2);border:2px solid var(--accent);box-shadow:0 0 14px var(--accent);z-index:1;}
.tl-item:last-child{border-bottom:none;}
.tl-co{font-size:11px;font-weight:600;color:var(--ink);letter-spacing:1px;margin-bottom:4px;}
.tl-dt{font-size:10px;color:var(--muted);letter-spacing:1px;}
.tl-badge{display:inline-block;margin-top:8px;font-size:9px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--accent3);background:rgba(0,255,136,.08);border:1px solid rgba(0,255,136,.2);padding:3px 8px;border-radius:3px;}
.tl-role{font-family:'Syne',sans-serif;font-size:22px;font-weight:700;color:var(--ink);margin-bottom:14px;letter-spacing:-.5px;}
.tl-pts{list-style:none;}
.tl-pts li{font-size:13px;color:var(--mid);font-weight:300;padding-left:18px;position:relative;margin-bottom:8px;line-height:1.7;}
.tl-pts li::before{content:'▸';position:absolute;left:0;color:var(--accent);font-size:10px;top:3px;}

/* PROJECTS */
.proj-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:36px;position:relative;overflow:hidden;transition:background .3s;cursor:none;}
.proj-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at var(--mx,50%) var(--my,50%),rgba(0,212,255,.06) 0%,transparent 65%);opacity:0;transition:opacity .3s;}
.proj-card:hover{background:var(--surface2);}
.proj-card:hover::before{opacity:1;}
.proj-num{font-size:10px;color:var(--muted);letter-spacing:2px;margin-bottom:18px;transition:color .3s;}
.proj-card:hover .proj-num{color:var(--accent);}
.proj-icon{font-size:30px;margin-bottom:14px;display:block;}
.proj-name{font-family:'Syne',sans-serif;font-size:22px;font-weight:700;color:var(--ink);margin-bottom:12px;}
.proj-desc{font-size:13px;color:var(--mid);font-weight:300;line-height:1.8;margin-bottom:24px;}
.proj-grid-mini{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:24px;}
.proj-mini-card{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:16px;}
.proj-mini-lbl{font-size:10px;color:var(--accent3);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;}
.proj-mini-val{font-size:12.5px;color:var(--mid);line-height:1.6;}
.proj-tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:20px;}
.proj-tag{font-size:10px;font-weight:500;letter-spacing:1px;text-transform:uppercase;color:var(--accent);background:rgba(0,212,255,.07);border:1px solid rgba(0,212,255,.15);padding:4px 10px;border-radius:3px;}

/* CERTS */
.cert-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.cert-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:22px;display:flex;align-items:flex-start;gap:14px;transition:border-color .3s,box-shadow .3s,transform .3s;cursor:none;}
.cert-card:hover{border-color:var(--accent);box-shadow:var(--glow);transform:translateY(-3px);}
.cert-ico{width:42px;height:42px;flex-shrink:0;background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.15);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;}
.cert-name{font-size:12.5px;font-weight:500;color:var(--ink);margin-bottom:3px;line-height:1.4;}
.cert-meta{font-size:11px;color:var(--muted);}
.cert-click{font-size:10px;color:var(--accent);margin-top:6px;letter-spacing:1px;}

/* CERT MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:1000;backdrop-filter:blur(8px);align-items:center;justify-content:center;}
.modal-box{background:var(--surface);border:1px solid var(--border);border-radius:12px;max-width:560px;width:90%;padding:32px;position:relative;box-shadow:0 0 60px rgba(0,212,255,.15);}
.modal-close{position:absolute;top:16px;right:16px;background:transparent;border:1px solid var(--border);color:var(--mid);font-size:18px;width:32px;height:32px;border-radius:4px;cursor:none;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;line-height:1;transition:border-color .2s,color .2s;}
.modal-close:hover{border-color:var(--accent);color:var(--accent);}
.modal-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;color:var(--ink);margin-bottom:4px;}
.modal-meta{font-size:11px;color:var(--muted);margin-bottom:20px;letter-spacing:1px;}
.modal-body{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:24px;text-align:center;}
.modal-note{font-size:12px;color:var(--mid);margin-bottom:16px;line-height:1.7;}

/* EDU */
.edu-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.edu-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:32px;position:relative;overflow:hidden;transition:border-color .3s;cursor:none;}
.edu-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent2),var(--accent));transform:scaleX(0);transform-origin:left;transition:transform .4s;}
.edu-card:hover{border-color:rgba(0,212,255,.3);}
.edu-card:hover::after{transform:scaleX(1);}
.edu-tag{display:inline-block;font-size:9px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--accent3);background:rgba(0,255,136,.08);border:1px solid rgba(0,255,136,.2);padding:3px 9px;border-radius:3px;margin-bottom:14px;}
.edu-school{font-family:'Syne',sans-serif;font-size:20px;font-weight:700;color:var(--ink);margin-bottom:4px;}
.edu-deg{font-size:12.5px;color:var(--mid);margin-bottom:10px;font-weight:300;}
.edu-loc{font-size:11px;color:var(--muted);}
.edu-score{font-family:'Syne',sans-serif;font-size:44px;font-weight:800;color:var(--accent);line-height:1;margin-top:14px;}

/* CONTACT */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.contact-left p{font-size:15px;color:var(--mid);font-weight:300;line-height:1.85;max-width:400px;}
.contact-avail{margin-top:32px;font-size:12px;color:var(--muted);}
.contact-avail .lbl{color:var(--accent3);margin-bottom:8px;}
.contact-avail div{margin-bottom:4px;}
.contact-links{display:flex;flex-direction:column;gap:14px;}
.c-link{display:flex;align-items:center;gap:16px;padding:18px 22px;background:var(--surface);border:1px solid var(--border);border-radius:8px;text-decoration:none;transition:border-color .3s,box-shadow .3s,transform .3s;cursor:none;}
.c-link:hover{border-color:var(--accent);box-shadow:var(--glow);transform:translateX(6px);}
.c-ico{font-size:18px;width:42px;height:42px;background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.15);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.c-lbl{font-size:10px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:2px;}
.c-val{font-size:13px;color:var(--ink);}
.c-arr{margin-left:auto;color:var(--border);transition:color .3s,transform .3s;}
.c-link:hover .c-arr{color:var(--accent);transform:translateX(4px);}

footer{text-align:center;padding:28px 48px;border-top:1px solid var(--border);font-size:11px;color:var(--muted);position:relative;z-index:10;display:flex;justify-content:space-between;align-items:center;}
.f-code{color:var(--accent3);}
.hex-deco{position:absolute;top:0;right:0;width:45%;height:100%;opacity:.025;pointer-events:none;background-image:repeating-linear-gradient(60deg,var(--accent) 0,var(--accent) 1px,transparent 0,transparent 50%),repeating-linear-gradient(120deg,var(--accent) 0,var(--accent) 1px,transparent 0,transparent 50%),repeating-linear-gradient(180deg,var(--accent) 0,var(--accent) 1px,transparent 0,transparent 50%);background-size:28px 50px;}

@keyframes fadeUp{from{opacity:0;transform:translateY(24px);}to{opacity:1;transform:translateY(0);}}
@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease;}
.reveal.visible{opacity:1;transform:none;}

@media(max-width:900px){
  nav{padding:14px 20px;}
  .hero{padding:100px 20px 60px;}
  .sec{padding:64px 20px;}
  .sec-dark .sec-inner{padding:0 20px;}
  .about-grid,.contact-grid,.edu-grid{grid-template-columns:1fr;}
  .cert-grid{grid-template-columns:1fr 1fr;}
  .tl-item{grid-template-columns:1fr;}
  .tl-item::before,.tl-item::after{display:none;}
  .proj-grid-mini{grid-template-columns:1fr;}
  footer{flex-direction:column;gap:8px;text-align:center;}
}
</style>
</head>
<body>

<div id="cursor"></div>
<div id="cursor-ring"></div>
<canvas id="canvas-bg"></canvas>

<nav>
  <a href="#" class="nav-logo">PSS<span>.dev</span></a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#experience">Experience</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#certs">Certs</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <div class="nav-status"><div class="status-dot"></div>Available for internships</div>
</nav>

<div style="position:relative;z-index:10;overflow:hidden;">
  <div class="hero">
    <div>
      <div class="hero-meta">ECS Student @ VIT Vellore &nbsp;·&nbsp; Data Analytics</div>
      <h1 class="hero-name">
        <span class="glitch-wrap" data-text="PRANAM">PRANAM</span><br>
        <span class="outline">S SHAH</span>
      </h1>
      <p class="hero-sub">I build <span class="typed-text" id="typed"></span><span class="blink"></span></p>
