        <div><div class="stat-num" data-count="3" data-dec="0">0</div><div class="stat-label">Certifications</div></div>
      </div>
    </div>
  </div>
  <div class="scroll-ind"><div class="scroll-line"></div>scroll</div>
  <div class="hex-deco"></div>
</div>

<!-- ABOUT -->
<section class="sec" id="about">
  <div class="corner ctlr"></div><div class="corner ctrr"></div>
  <div class="sec-lbl reveal">About</div>
  <h2 class="sec-h reveal">Who I <span class="dim">Am</span></h2>
  <div class="about-grid">
    <div class="terminal reveal">
      <div class="t-bar">
        <div class="td" style="background:#ff5f56"></div>
        <div class="td" style="background:#ffbd2e"></div>
        <div class="td" style="background:#27c93f"></div>
        <span class="t-title">pranam@vit:~$ profile.sh</span>
      </div>
      <div class="t-body">
        <div><span class="tp">❯ </span><span class="tc">whoami</span></div>
